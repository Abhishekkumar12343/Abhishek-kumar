rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: users
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: simulations
    // Fields: userId, concept, code, controls, createdAt
    //
    // Collection: assets
    // Fields: userId, type, url, prompt, model, createdAt
    //
    // Collection: chats/{chatId}/messages
    // Fields: userId, role, content, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abhishekkumar24404@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidSimulation(data) {
      return data.keys().hasAll(['userId', 'concept', 'code']) &&
             data.userId == request.auth.uid &&
             data.concept is string && data.concept.size() < 500 &&
             data.code is string && data.code.size() < 100000 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['userId', 'type', 'url', 'prompt']) &&
             data.userId == request.auth.uid &&
             data.type in ['image', 'video'] &&
             data.url is string && data.url.size() < 2048 &&
             data.prompt is string && data.prompt.size() < 1000 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'content']) &&
             data.userId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() < 10000 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
    }

    match /simulations/{simulationId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSimulation(request.resource.data);
      allow update: if isDocOwner() && isValidSimulation(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /assets/{assetId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAsset(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
